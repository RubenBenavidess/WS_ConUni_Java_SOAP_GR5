<a:Creator>dario</a:Creator>
<a:ModificationDate>1776474486</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>UnidadLongitud</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    try {
        return UnidadLongitud.valueOf(unidad.trim().toUpperCase());
    } catch (IllegalArgumentException e) {
        throw new RuntimeException(&quot;Unidad de longitud inválida: &quot; + unidad);
    }
}
