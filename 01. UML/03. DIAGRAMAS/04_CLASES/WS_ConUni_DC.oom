<a:TemplateBody>        {
    
    if (&quot;Monster&quot;.equals(usuario) &amp;&amp; &quot;Monster9&quot;.equals(contrasenia)) {
        return AdministradorTokens.generarToken();
    }
    throw new RuntimeException(&quot;Credenciales incorrectas&quot;);
}
