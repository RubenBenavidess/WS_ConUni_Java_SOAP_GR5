@startuml
title "DS_01_INICIALIZAR_CLIENTE_SOAP (Corregido)"

participant "APLICACION\n(Main)" as Main
participant "LOGIN_VISTA" as LoginVista
participant "LOGIN_CONTROLADOR" as LoginControlador
participant "CLIENTE_WS_CONVERSOR" as ClienteWS
participant "ENDPOINT_WSDL" as WSDL

Main -> LoginVista: 1. new LoginVista() / setVisible(true)
activate LoginVista

LoginVista -> LoginControlador: 2. new LoginControlador()
activate LoginControlador

LoginControlador -> ClienteWS: 3. new ClienteWSConversor()
activate ClienteWS

ClienteWS -> ClienteWS: 4. inicializarPuerto()
activate ClienteWS

ClienteWS -> ClienteWS: 5. construirBasesUrl()
note right: Revisa System.getProperty("ws.base.url"),\nSystem.getenv("WS_BASE_URL"),\ny URLs por defecto.
deactivate ClienteWS

loop Para cada URL base candidata
    ClienteWS -> WSDL: 6. Arma URL de WSDL (e.g., .../WSConversorUnidades?wsdl)
    ClienteWS -> WSDL: 7. Intenta Service.create(wsdlUrl, qname)
    activate WSDL
    WSDL --> ClienteWS: 8. Retorna instancia de Service
    deactivate WSDL
    
    ClienteWS -> ClienteWS: 9. port = service.getPort(...)
    ClienteWS -> ClienteWS: 10. Fija BindingProvider.ENDPOINT_ADDRESS_PROPERTY
    ClienteWS -> ClienteWS: 11. configurarManejadorToken(port)
    note right: Añade ManejadorTokenSOAP al HandlerChain del binding.
    
    ClienteWS --> LoginControlador: 12. Retorna puerto inicializado
    deactivate ClienteWS
    
    LoginControlador --> LoginVista: 13. 
    deactivate LoginControlador
    
    LoginVista --> Main: 14. 
    deactivate LoginVista
    break
end

@enduml
