<o:Operation Id="o78">
<a:ObjectID>6EE93726-001C-42EB-B89E-D03D1B0128C7</a:ObjectID>
<a:Name>convertir</a:Name>
<a:Code>convertir</a:Code>
<a:CreationDate>1776474487</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1776474487</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>double</a:ReturnType>
<a:TemplateBody>{
    if (conversor == null) {
        throw new IllegalStateException(&quot;No se ha inyectado un conversor&quot;);
    }
    return conversor.convertir(valor, origen, destino);
}
</a:TemplateBody>
