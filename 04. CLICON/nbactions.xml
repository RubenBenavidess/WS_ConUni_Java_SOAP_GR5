    <action>
        <actionName>run</actionName>
        <packagings>
            <packaging>jar</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.1:java</goal>
        </goals>
        <properties>
            <exec.mainClass>ec.edu.monster.Main</exec.mainClass>
            <exec.appArgs></exec.appArgs>
        </properties>
    </action>
</actions>
