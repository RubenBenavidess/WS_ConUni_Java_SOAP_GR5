<c:Operations>
<o:Operation Id="o69">
<a:ObjectID>C70FDD80-7163-4123-9FE7-D562D4E39C82</a:ObjectID>
<a:Name>generarToken</a:Name>
<a:Code>generarToken</a:Code>
<a:CreationDate>1776474486</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1776474486</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>String</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{

    String token = UUID.randomUUID().toString();
    tokensActivos.add(token);
    return token;
}
</a:TemplateBody>
</o:Operation>
<o:Operation Id="o70">
<a:ObjectID>3AFFF3ED-244F-45B4-84EB-A0D23E9E2E59</a:ObjectID>
<a:Name>validarToken</a:Name>
<a:Code>validarToken</a:Code>
<a:CreationDate>1776474486</a:CreationDate>
<a:Creator>dario</a:Creator>
<a:ModificationDate>1776474486</a:ModificationDate>
<a:Modifier>dario</a:Modifier>
<a:ReturnType>boolean</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    return tokensActivos.contains(token);
}
</a:TemplateBody>
